# bplus 環境変数テンプレート
# このファイルをコピーして .env を作成してください: cp .env.example .env

# --- PostgreSQL (Docker db サービス) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=bplus_development

# --- Rails (api) ---
RAILS_ENV=development
# api コンテナから db へ接続する際のホスト名（compose のサービス名）
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=password

# --- フロント（apps/admin・apps/participant / Vite 共通） ---
# Vite は VITE_ プレフィックスの変数のみクライアントに公開する
VITE_API_BASE_URL=http://localhost:3000/api/v1
